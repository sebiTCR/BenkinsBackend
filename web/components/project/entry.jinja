 {#def project={} #}

<div class="project_entry flex justify-around">
    <div class="flex flex-col">
        <p><b> {{project.name}} </b></p>
        <p class="text-[#EFF8E25a]"><b> {{project.path}} </b></p>
    </div>

    <Project.Status status={{project.status}}/>

    <div class="flex flex-col">
        <h1><b>Builds</b></h1>
        <select>
            {%for build in project.builds%}
                <option>{{build.version}}</option>
            {%endfor%}
        </select>
    </div>

    <div class="flex flex-col">
        <button onclick="alert('building')">Build</button>
        <button onclick="download_build()">Download</button>
    </div>
</div>